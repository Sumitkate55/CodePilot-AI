APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://codepilot:codepilot@localhost:5432/codepilot
CORS_ORIGINS=["http://localhost:5173"]
TRUSTED_HOSTS=["localhost","127.0.0.1"]
JWT_SECRET_KEY=development-only-secret-change-before-production-32-chars
# Use "ollama" for free local AI or "openai" for the paid OpenAI API.
AI_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_PROJECT_SUMMARY_MODEL=gpt-5
OPENAI_REPOSITORY_CHAT_MODEL=gpt-5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=90
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Lightweight defaults for Apple Silicon Macs with 8 GB memory.
OLLAMA_CHAT_MODEL=qwen2.5-coder:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=300
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=codepilot_repository_chunks
REPOSITORY_RAG_CHUNK_CHARACTERS=2000
REPOSITORY_RAG_CHUNK_OVERLAP_LINES=12
REPOSITORY_RAG_MAX_FILE_BYTES=524288
REPOSITORY_RAG_MAX_CHUNKS=10000
REPOSITORY_RAG_SEARCH_LIMIT=6
REPOSITORY_RAG_MIN_SCORE=0.2
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REPOSITORY_STORAGE_ROOT=data/repositories
REPOSITORY_UPLOAD_MAX_BYTES=104857600
REPOSITORY_EXTRACTED_MAX_BYTES=524288000
REPOSITORY_ANALYSIS_MAX_FILE_BYTES=2097152
REPOSITORY_ANALYSIS_MAX_SYMBOLS=10000
REPOSITORY_ANALYSIS_MAX_FOLDERS=500
